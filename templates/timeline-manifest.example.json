{
  "project": {
    "name": "sample-video",
    "width": 1920,
    "height": 1080,
    "fps": 60,
    "output": "renders/final.mp4"
  },
  "segments": [
    {
      "id": "scene-01",
      "video": "renders/scene-01.mp4",
      "source_duration": 9.0,
      "target_duration": 10.0,
      "audio": "assets/scene-01-narration.mp3",
      "strategy": "retime-to-audio"
    },
    {
      "id": "scene-02",
      "video": "renders/scene-02.mp4",
      "source_duration": 13.0,
      "target_duration": 16.5,
      "audio": "assets/scene-02-narration.mp3",
      "strategy": "segment-map",
      "maps": [
        { "source_start": 0.0, "source_end": 4.0, "target_duration": 5.8 },
        { "hold_source_time": 4.0, "target_duration": 1.5 },
        { "source_start": 4.0, "source_end": 13.0, "target_duration": 9.2 }
      ]
    }
  ],
  "captions": {
    "script": "assets/script.txt",
    "style": "templates/caption-style.ass",
    "output": "captions/final.ass"
  },
  "music": {
    "file": "assets/music.mp3",
    "start_offset": 0.7,
    "duck_under_narration": true,
    "end_silence_seconds": 2.0
  },
  "proofs": [
    { "time": 10.0, "label": "scene-02-start" },
    { "time": 27.0, "label": "chart-label-visible" }
  ]
}

